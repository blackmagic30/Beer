{
  "name": "melb-beer-bot",
  "version": "0.1.0",
  "private": true,
  "description": "MVP Twilio + ElevenLabs beer price calling bot for Melbourne venues.",
  "type": "module",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "rm -rf dist && tsc --project tsconfig.json",
    "start": "node dist/src/server.js",
    "venues:import": "tsx scripts/import-melbourne-venues.ts",
    "venues:review": "tsx scripts/export-call-review.ts",
    "venues:call": "tsx scripts/batch-call-venues.ts",
    "calls:recover-stale": "tsx scripts/recover-stale-call-runs.ts",
    "results:reparse": "tsx scripts/reparse-call-runs.ts",
    "test": "vitest run",
    "check": "npm run build && npm run test"
  },
  "dependencies": {
    "@elevenlabs/elevenlabs-js": "^2.41.1",
    "@supabase/supabase-js": "^2.103.0",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "node-fetch": "^2.7.0",
    "openai": "^6.33.0",
    "twilio": "^5.13.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "directories": {
    "test": "test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
